{
  "name": "heritage-edit/platform",
  "description": "THE HERITAGE EDIT — Ultra-luxury headless e-commerce platform",
  "type": "project",
  "require": {
    "php": "^8.1",
    "vlucas/phpdotenv": "^5.5",
    "guzzlehttp/guzzle": "^7.8",
    "firebase/php-jwt": "^6.9",
    "ramsey/uuid": "^4.7",
    "monolog/monolog": "^3.5",
    "filp/whoops": "^2.15"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "HeritageEdit\\": "src/"
    }
  },
  "scripts": {
    "worker": "php src/Workers/ProductEnrichmentWorker.php"
  },
  "config": {
    "optimize-autoloader": true
  }
}
